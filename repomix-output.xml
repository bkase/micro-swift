    baseOffset: Int64,
    fileID: FileID
  ) -> [Span] {
    errorSpans.map { error in
      let start = ByteOffset(rawValue: baseOffset + Int64(error.start))
      let end = ByteOffset(rawValue: baseOffset + Int64(error.end))
      return try! Span.validated(
