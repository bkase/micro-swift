    self.lexingShell = lexingShell
  }

  public func lexFile(
    bytes: [UInt8],
    artifact: ArtifactRuntime,
    options: LexOptions
  ) throws -> [PageLexResult] {
    let source = SourceBuffer(
      fileID: FileID(rawValue: 0),
      path: "<memory>",
      bytes: Data(bytes)
    )
    let result = lexingShell.lexSource(source: source, artifact: artifact, options: options)
