#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/common.sh"

ROOT_DIR="$(repo_root)"

usage() {
  cat <<USAGE
Usage: ./dev <command>
  doctor
  format
  lint
  build
  test
  mlx-smoke
  verify
  install-hooks
  run
USAGE
}

resolve_mlx_binary() {
  local candidates=(
    "$ROOT_DIR/.build/Build/Products/Debug/micro-swift"
    "$ROOT_DIR/.build/Build/Products/Release/micro-swift"
    "$ROOT_DIR/.build/debug/micro-swift"
    "$ROOT_DIR/.build/xcodebuild/micro-swift"
  )

  for candidate in "${candidates[@]}"; do
    if [[ -x "$candidate" ]]; then
      echo "$candidate"
      return 0
    fi
  done

  local found=""
  found="$(find "$ROOT_DIR/.build" -type f -perm -111 -name micro-swift 2>/dev/null | sort | head -n 1 || true)"
  if [[ -n "$found" ]]; then
    echo "$found"
    return 0
  fi

  return 1
}

cmd="${1:-}"; shift || true

case "${cmd}" in
  doctor)
    shift || true
    "$SCRIPT_DIR/doctor.sh" "$@"
    ;;
  format)
    require_command swift
    run_or_dry swift format --in-place --recursive .
    ;;
  lint)
    require_command swift
    run_or_dry swift format lint --recursive --strict .
    ;;
  build)
    require_command swift
    run_or_dry swift build
    ;;
  test)
    require_command swift
    run_or_dry swift test
    ;;
  mlx-smoke)
    require_command swift
    if command -v xcodebuild >/dev/null 2>&1; then
      run_or_dry xcodebuild -scheme micro-swift -configuration Debug -destination "platform=macOS" -derivedDataPath "$ROOT_DIR/.build" build
    else
      run_or_dry swift build --product micro-swift
    fi

    binary="$(resolve_mlx_binary)"
    if [[ -z "$binary" ]]; then
      echo "unable to locate micro-swift executable after build" >&2
      exit 1
    fi
    "$SCRIPT_DIR/mlx-run" "$binary" mlx-smoke --json
    ;;
  verify)
    "$0" format
    "$0" lint
    "$0" build
    "$0" test
    ;;
  install-hooks)
    mkdir -p "$ROOT_DIR/.git/hooks"
    ln -sf "$ROOT_DIR/.githooks/pre-commit" "$ROOT_DIR/.git/hooks/pre-commit"
    echo "installed hook: .githooks/pre-commit -> .git/hooks/pre-commit"
    ;;
  run)
    require_command swift
    swift run micro-swift "$@"
    ;;
  *)
    usage
    exit 1
    ;;
esac
